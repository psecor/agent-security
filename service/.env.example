# agent-security service config. Copy to service/.env and fill in.

# --- Scanner ---

# Comma-separated absolute paths to project roots. The scanner walks these
# and treats every immediate subdirectory containing an AGENTS.md as a project.
PROJECT_ROOTS=/home/secorp/termag/projects

# Where the scanner writes findings/<project>.{json,md}. Defaults to <repo>/findings.
# Also where the server reads from. Leave unset to use the default
# (recommended — keeps findings in the repo).
# FINDINGS_DIR=

# Selector LOC threshold. Projects with fewer changed LOC since their
# last_scanned_sha are skipped on `--all` (overridden by --force).
LOC_THRESHOLD=200

# Used by the triage layer (milestone 2). Required once Claude is in the loop;
# safe to leave blank for tool-only scans.
ANTHROPIC_API_KEY=


# --- Web service (milestone 4+) ---

# Public URL the service is reachable at. localhost for dev; https://secorp.net
# (the Apache front) in prod. Used to construct OAuth callback URLs.
BASE_URL=http://localhost:3046

# All routes mount under this prefix. Must match Apache's ProxyPass and (later)
# the UI's vite base / BrowserRouter basename.
PATH_PREFIX=/security

# Listen port. Apache proxies /security to 127.0.0.1:PORT in prod.
PORT=3046

# Long random hex (e.g. `openssl rand -hex 32`). Rotating invalidates all
# active human sessions.
SESSION_SECRET=

# Google OAuth client. Redirect URI is ${BASE_URL}${PATH_PREFIX}/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated email allowlist for human users.
ALLOWED_EMAILS=secorp@gmail.com

# Built UI bundle. Defaults to <repo>/ui/dist. The server returns a 503
# placeholder on /security/ until this exists (milestone 5).
# UI_DIST=
