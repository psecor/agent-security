# agent-security service config. Copy to service/.env and fill in.

# --- Scanner ---

# Comma-separated absolute paths to project roots. The scanner walks these
# and treats every immediate subdirectory containing an AGENTS.md as a project.
# Required — no default. Example: /home/alice/code,/home/alice/work
PROJECT_ROOTS=

# Where the scanner writes findings (under projects/ and hosts/). Defaults to
# <repo>/findings. Multi-host deployments typically point this at a clone of a
# separate (often private) findings repo so every host pushes into the same
# git tree, keeping the source repo open-source-clean. The web UI host reads
# its dashboard out of this same path.
# FINDINGS_DIR=

# Host scanning. When `true`, `npm run scanner -- run --all` includes a host
# scan alongside any qualifying project scans, and `--host` is available as a
# direct CLI flag. Default: false (scanner only walks PROJECT_ROOTS).
# SCAN_HOST=

# Hostname used as the basename for findings/hosts/<HOST_NAME>.{json,md}.
# Defaults to `os.hostname()`. Override when the kernel hostname is generic
# ("ubuntu", "ip-10-0-0-5") or when multiple hosts could otherwise collide
# in the shared findings repo.
# HOST_NAME=

# Selector LOC threshold. Projects with fewer changed LOC since their
# last_scanned_sha are skipped on `--all` (overridden by --force).
LOC_THRESHOLD=200

# Used by the triage layer (milestone 2). Required once Claude is in the loop;
# safe to leave blank for tool-only scans.
ANTHROPIC_API_KEY=

# Identity used for the bot commit each scan writes to findings/. Defaults are
# fine for local use; set these to a domain/email you control if you publish
# the repo or want commits attributed somewhere routable.
# SCANNER_BOT_USER=agent-security[bot]
# SCANNER_BOT_EMAIL=agent-security-bot@example.invalid


# --- Web service (milestone 4+) ---

# Public-facing base URL where this service is reachable. Used to construct
# OAuth callback URLs — must match the redirect URI configured in Google Cloud.
BASE_URL=https://example.com

# All routes mount under this prefix. Must match Apache's ProxyPass and (later)
# the UI's vite base / BrowserRouter basename.
PATH_PREFIX=/security

# Listen port. Apache proxies /security to 127.0.0.1:PORT in prod.
PORT=3046

# Long random hex (e.g. `openssl rand -hex 32`). Rotating invalidates all
# active human sessions.
SESSION_SECRET=

# Google OAuth client. Redirect URI is ${BASE_URL}${PATH_PREFIX}/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated email allowlist for human users. Required — no default.
ALLOWED_EMAILS=

# Built UI bundle. Defaults to <repo>/ui/dist. The server returns a 503
# placeholder on /security/ until this exists (milestone 5).
# UI_DIST=
